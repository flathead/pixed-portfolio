---
import BaseLayout from '../layouts/BaseLayout.astro';

const buildTime = new Date().toISOString();
---

<BaseLayout title="pixed-portfolio — M1 OK">
  <main class="container" style="padding: 80px 0;">
    <h1
      style="font-family: var(--font-display); color: var(--green); text-transform: uppercase; letter-spacing: 0.05em; font-size: var(--display-md); line-height: 1.5;"
    >
      flathead.is-a.dev — M1 Foundation OK
    </h1>
    <p style="margin-top: var(--space-5); color: var(--text);">
      Astro skeleton deployed. Real homepage lands in M2.
    </p>
    <p
      style="margin-top: var(--space-2); color: var(--text-muted); font-family: var(--font-code); font-size: var(--text-sm);"
    >
      Build: {buildTime}
    </p>
  </main>
</BaseLayout>
